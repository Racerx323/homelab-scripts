Windows Registry Editor Version 5.00

; attribution: https://github.com/jimbrig/obsidian_published/blob/main/docs/Windows/SFC%20and%20DISM%20Commands.md
; Assumptions: PowerShell version 7 installed
;  - Default WT profile - PowerShell 7
; Each command explicitly elevates a new Windows Terminal window with Start-Process -Verb RunAs.
; Repair commands use absolute system paths and start in %SystemRoot%\System32.
; ============================================================================
; System File Checker (SFC) Context Menu
; ============================================================================
[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair]
"Icon"="UserAccountControlSettings.exe"
"MUIVerb"="System Repair Tools"
"Position"="Bottom"
"SubCommands"=""

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\01Scannow]
"HasLUAShield"=""
"MUIVerb"="Run SFC /Scannow"

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\01Scannow\command]
@="\"C:\\Program Files\\PowerShell\\7\\pwsh.exe\" -NoProfile -WindowStyle Hidden -Command \"Start-Process -FilePath ($env:LOCALAPPDATA + '\\Microsoft\\WindowsApps\\wt.exe') -Verb RunAs -ArgumentList @('-w','new','new-tab','--title',([char]34 + 'SFC Scan' + [char]34),'-p',([char]34 + 'PowerShell 7' + [char]34),'-d',([char]34 + $env:SystemRoot + '\\System32' + [char]34),([char]34 + $env:ComSpec + [char]34),'/k',([char]34 + $env:SystemRoot + '\\System32\\sfc.exe' + [char]34),'/scannow')\""

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\02ViewLog]
"MUIVerb"="View log for SFC"
"Icon"="notepad.exe"

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\02ViewLog\command]
@="\"C:\\Program Files\\PowerShell\\7\\pwsh.exe\" -NoProfile -WindowStyle Hidden -Command \"Start-Process -FilePath ($env:LOCALAPPDATA + '\\Microsoft\\WindowsApps\\wt.exe') -Verb RunAs -ArgumentList @('-w','new','new-tab','--title',([char]34 + 'View SFC Log' + [char]34),'-p',([char]34 + 'PowerShell 7' + [char]34),'-d',([char]34 + $env:SystemRoot + '\\System32' + [char]34),([char]34 + $env:ProgramFiles + '\\PowerShell\\7\\pwsh.exe' + [char]34),'-NoExit','-EncodedCommand','')\""

; ============================================================================
; DISM Image Tools Context Menu
; ============================================================================
[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\03CheckHealth]
"HasLUAShield"=""
"MUIVerb"="Check Health of Windows Image"

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\03CheckHealth\command]
@="\"C:\\Program Files\\PowerShell\\7\\pwsh.exe\" -NoProfile -WindowStyle Hidden -Command \"Start-Process -FilePath ($env:LOCALAPPDATA + '\\Microsoft\\WindowsApps\\wt.exe') -Verb RunAs -ArgumentList @('-w','new','new-tab','--title',([char]34 + 'DISM CheckHealth' + [char]34),'-p',([char]34 + 'PowerShell 7' + [char]34),'-d',([char]34 + $env:SystemRoot + '\\System32' + [char]34),([char]34 + $env:ComSpec + [char]34),'/k',([char]34 + $env:SystemRoot + '\\System32\\Dism.exe' + [char]34),'/Online','/Cleanup-Image','/CheckHealth')\""

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\04ScanHealth]
"HasLUAShield"=""
"MUIVerb"="Scan Health of Windows Image"

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\04ScanHealth\command]
@="\"C:\\Program Files\\PowerShell\\7\\pwsh.exe\" -NoProfile -WindowStyle Hidden -Command \"Start-Process -FilePath ($env:LOCALAPPDATA + '\\Microsoft\\WindowsApps\\wt.exe') -Verb RunAs -ArgumentList @('-w','new','new-tab','--title',([char]34 + 'DISM ScanHealth' + [char]34),'-p',([char]34 + 'PowerShell 7' + [char]34),'-d',([char]34 + $env:SystemRoot + '\\System32' + [char]34),([char]34 + $env:ComSpec + [char]34),'/k',([char]34 + $env:SystemRoot + '\\System32\\Dism.exe' + [char]34),'/Online','/Cleanup-Image','/ScanHealth')\""

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\05RestoreHealth]
"HasLUAShield"=""
"MUIVerb"="Repair Windows Image"

[HKEY_CLASSES_ROOT\DesktopBackground\Shell\SystemRepair\Shell\05RestoreHealth\command]
@="\"C:\\Program Files\\PowerShell\\7\\pwsh.exe\" -NoProfile -WindowStyle Hidden -Command \"Start-Process -FilePath ($env:LOCALAPPDATA + '\\Microsoft\\WindowsApps\\wt.exe') -Verb RunAs -ArgumentList @('-w','new','new-tab','--title',([char]34 + 'DISM RestoreHealth' + [char]34),'-p',([char]34 + 'PowerShell 7' + [char]34),'-d',([char]34 + $env:SystemRoot + '\\System32' + [char]34),([char]34 + $env:ComSpec + [char]34),'/k',([char]34 + $env:SystemRoot + '\\System32\\Dism.exe' + [char]34),'/Online','/Cleanup-Image','/RestoreHealth')\""
